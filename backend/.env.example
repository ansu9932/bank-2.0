# Server
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://bank-2-0-5ur5.vercel.app

# Database (Hostinger local MySQL — no external SSL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=alister_bank
DB_USER=root
DB_PASS=your_secure_password
# Set to "true" for a SINGLE deploy to realign the schema (alter mode), then
# remove it. Leaving it "true" on every boot re-adds duplicate indexes and will
# eventually crash MySQL with "Too many keys specified; max 64 keys allowed".
DB_SYNC_ALTER=false

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_long_and_random
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_min_64_chars
JWT_REFRESH_EXPIRE=30d

# Email (SMTP — Hostinger relay; 'from' header must match SMTP_USER)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@divyamoolya.in
SMTP_PASS=your_email_password
EMAIL_FROM="Alister Bank <info@divyamoolya.in>"

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_key
CSRF_SECRET=your_csrf_secret

# Cloudflare Turnstile (bot protection) — backend SECRET key (server-side only)
CLOUDFLARE_TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key

# Razorpay (UPI instant deposits — core payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# RazorpayX (outgoing payouts). The source virtual account funds are debited
# from; required for /api/payments/payout. NEFT_SETTLEMENT_MINUTES controls the
# simulated NEFT batch-clearing delay (default 3 minutes).
RAZORPAYX_ACCOUNT_NUMBER=your_razorpayx_account_number
NEFT_SETTLEMENT_MINUTES=3

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Bank Config
BANK_NAME="Alister Bank"
BANK_IFSC_PREFIX=ALST
BANK_SWIFT=ALSTINBB
DAILY_TRANSFER_LIMIT=500000
IMPS_LIMIT=200000
NEFT_LIMIT=500000
RTGS_MIN=200000
