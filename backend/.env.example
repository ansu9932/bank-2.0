# Environment switch: 'sandbox' (default) or 'production'. Selects the base URL
#   sandbox    → https://sandbox.cashfree.com/verification
#   production → https://api.cashfree.com/verification
CASHFREE_ENV=sandbox
# Cashfree verification API version header (x-api-version). Omitting this is a
# common cause of blanket non-2xx rejections. Override if your dashboard
# mandates a different date-based version.
CASHFREE_API_VERSION=2025-01-01
# Optional explicit base-URL override (leave blank to use the switch above).
CASHFREE_VERIFICATION_BASE_URL=
# Optional PAN resource path (default '/pan' → '<base>/pan'). Set to '/pan/advance'
# or another product path if your Cashfree account uses a different PAN API.
CASHFREE_PAN_RESOURCE_PATH=/pan
# Placeholder name sent to satisfy the sync schema's required `name` field when
# the caller performs a pure PAN lookup without supplying a real name.
CASHFREE_PAN_NAME_PLACEHOLDER=Alister Bank Customer
