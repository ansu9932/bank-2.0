# Server
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://alisterbank.com

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=alister_bank
DB_USER=root
DB_PASS=your_secure_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_long_and_random
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_min_64_chars
JWT_REFRESH_EXPIRE=30d

# Email (SMTP)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@alisterbank.com
SMTP_PASS=your_email_password
EMAIL_FROM="Alister Bank <noreply@alisterbank.com>"

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_key
CSRF_SECRET=your_csrf_secret

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Bank Config
BANK_NAME="Alister Bank"
BANK_IFSC_PREFIX=ALST
BANK_SWIFT=ALSTINBB
DAILY_TRANSFER_LIMIT=500000
IMPS_LIMIT=200000
NEFT_LIMIT=500000
RTGS_MIN=200000
